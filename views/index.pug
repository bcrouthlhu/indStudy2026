extends layout

block content
  .dashboard-hero
    if user
      h2 Welcome, #{user.displayName || user.email}
    else
      h2 Welcome to the dashboard.
      p Sign in to personalize your experience.
  .dashboard-grid
    .tile.weather-tile
      .tile-header
        span Weather
      .tile-body.weather-body
        if weather && weather.temperature != null
          .weather-inner
            .weather-value #{weather.temperature.toFixed(1)}#{weather.unit}
            .weather-info
              .weather-subtext Chance of precipitation: #{weather.precipitationProbability}%
              if weather.apparentTemperature != null
                .weather-extra Feels like: #{weather.apparentTemperature.toFixed(1)}#{weather.unit}
        else
          p.placeholder Weather unavailable
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/aqi_bar.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/aqi_heatmap.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/aqi_trend.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/summAllg.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/tempAllg.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/uv_bar.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/uv_map.html", width="100%", height="500", style="border:none")
    .tile
      .tile-header
        span UV Map
      .tile-body
        iframe(src="/uv_potential.html", width="100%", height="500", style="border:none")
