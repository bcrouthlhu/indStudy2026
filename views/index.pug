extends layout

block content
  .dashboard-hero
    if user
      h2 Welcome, #{user.displayName || user.email}
    else
      h2 Welcome!
      p Sign in to personalize your experience.
  .dashboard-grid
    .tile.weather-tile
      .tile-header
        span Weather
      .tile-body.weather-body
        if weather && weather.temperature != null
          .weather-inner
            .weather-value #{weather.temperature.toFixed(1)}#{weather.unit}
            .weather-info
              .weather-subtext Chance of precipitation: #{weather.precipitationProbability}%
              if weather.apparentTemperature != null
                .weather-extra Feels like: #{weather.apparentTemperature.toFixed(1)}#{weather.unit}
        else
          p.placeholder Weather unavailable
    .tile
      .tile-header
        span Appointments
      .tile-body
        p May 9th, 2026 Tuesday, 8:00AM - Physisican Appointment
    .tile
      .tile-header
        span Calendar
      .tile-body
        p No other events.
    .tile
      .tile-header
        span Alerts
      .tile-body
        p No alerts : )
