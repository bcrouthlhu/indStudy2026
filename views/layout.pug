doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title Demo Medical Site
    link(rel="stylesheet" href="/styles.css")

  body
    header.site-header
      .site-brand
        img(src='path/to/image.jpg', class='site-logo')
        h1 Demo Medical Site

      .header-actions
        if user
          a.button.secondary(href='/logout') Sign out
        else
          a.button.secondary(href='/signin') Sign in

    .page
      aside.sidebar
        nav.sidebar-nav
          ul
            li
              a(href='/') Dashboard
            li
              a(href='/analytics') Analytics
            li
              a(href='/settings') Settings

          footer.sidebar-footer
            p#last-update Loading...

      main.page-content
        block content


    script.
      fetch('/api/date')
        .then(res => res.json())
        .then(data => {
          if (document.getElementById('last-update')) {
            document.getElementById('last-update').textContent = 'Last Update: ' + data.date;
          }
        })
        .catch(() => {
          if (document.getElementById('last-update')) {
            document.getElementById('last-update').textContent = 'Last Update: ' + new Date().toLocaleDateString();
          }
        });